    {
      "name": "06 - Endpoints Protegidos (con JWT)",
      "description": "Valida que los endpoints de negocio funcionan con el token obtenido en el login.",
      "item": [
        {
          "name": "GET /api/users (lista usuarios)",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/users",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "description": "Lista todos los usuarios. Requiere JWT."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Contiene users array', () => {",
                  "  pm.expect(pm.response.json().data.users).to.be.an('array');",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "GET /api/groups (mis grupos)",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/groups",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
