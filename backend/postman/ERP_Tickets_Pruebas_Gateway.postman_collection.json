                  "pm.test('Service es tickets', () => pm.expect(pm.response.json().data.service).to.eql('tickets'));",
                  "pm.test('Mensaje pong', () => pm.expect(pm.response.json().data.message).to.eql('pong'));"
                ]
              }
            }
          ]
        },
        {
          "name": "GET /api/tickets/test/db",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/tickets/test/db",
            "description": "Verifica conexión a PostgreSQL desde tickets service."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('DB conectada', () => pm.expect(pm.response.json().data.db_connected).to.be.true);"
                ]
              }
            }
          ]
        },
        {
          "name": "GET /api/tickets/test/tables",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/tickets/test/tables",
            "description": "Lista tablas vistas desde el microservicio de tickets."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Tabla tickets existe', () => {",
                  "  const names = pm.response.json().data.tables.map(t => t.table_name);",
                  "  pm.expect(names).to.include('tickets');",
                  "  pm.expect(names).to.include('comentarios');",
                  "  pm.expect(names).to.include('historial_tickets');",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "GET /api/tickets/test/counts",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/tickets/test/counts",
            "description": "Cuenta tickets, estados, prioridades y comentarios."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('5 estados seed', () => pm.expect(pm.response.json().data.counts.estados).to.eql(5));",
                  "pm.test('4 prioridades seed', () => pm.expect(pm.response.json().data.counts.prioridades).to.eql(4));"
                ]
              }
            }
          ]
        },
        {
          "name": "GET /api/tickets/catalogs/estados",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/tickets/catalogs/estados",
            "description": "Catálogo de estados (público, sin JWT)."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Al menos 5 estados', () => {",
                  "  pm.expect(pm.response.json().data.estados.length).to.be.gte(5);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "GET /api/tickets/catalogs/prioridades",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/tickets/catalogs/prioridades",
            "description": "Catálogo de prioridades (público, sin JWT)."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('4 prioridades', () => {",
                  "  pm.expect(pm.response.json().data.prioridades.length).to.eql(4);",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    },
